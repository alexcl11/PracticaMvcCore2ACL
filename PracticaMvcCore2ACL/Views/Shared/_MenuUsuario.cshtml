@using System.Security.Claims
@{
    int contador = 0;
    if (Context.Session.GetObject<List<Libros>>("CARRITO") != null)
    {
        contador = Context.Session.GetObject<List<Libros>>("CARRITO").Count();
    }
}
﻿@if (!Context.User.Identity.IsAuthenticated)
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Usuarios" asp-action="Perfil">Log In</a>
    </li>
    
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Usuarios" asp-action="Carrito">Carrito: @contador</a>
    </li>
}
else
{
    
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Managed" asp-action="Logout">Log Out</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Usuarios" asp-action="Perfil">Perfil</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Usuarios" asp-action="Carrito">Carrito: @contador</a>
    </li>

}