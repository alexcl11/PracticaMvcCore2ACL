@model List<Generos>

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        Generos
    </a>
    <ul class="dropdown-menu">
        @foreach(Generos genero in Model)
        {            
            <li>
                <a  asp-controller="Libros" asp-action="LibrosPorGenero" asp-route-id="@genero.IdGenero"
                    class="dropdown-item">
                    @genero.Nombre
                </a>
            </li>
        }
        
    </ul>
</li>